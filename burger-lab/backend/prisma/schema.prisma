//Gera o cliente Prisma para usar no backend.
generator client {
  provider = "prisma-client-js"
  // O output define onde o Prisma Client será gerado:
  // output   = "../src/generated/prisma"
}

datasource db {
  // O banco usado será PostgreSQL.
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  cep String
  admin Boolean @default(false)

  cartItems CartItem[]

  @@map("users")
}

model Product {
  id String @id @default(cuid())
  name String
  description String
  price Int
  category String
  img String
  createdAt DateTime @default(now())

  cartItems CartItem[]

  @@map("products")
}

model CartItem {
  id String @id @default(uuid())
  quantity Int @default(1)

  productId String
  product Product @relation(fields: [productId], references: [id])

  userId String
  user User @relation(fields: [userId], references: [id])

  @@map("cart_items")
}